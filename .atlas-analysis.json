  "keyFeatures": [
    "Interactive terminal REPL powered by Claude AI for coding tasks",
    "Built-in file editing, reading, and searching tools",
    "Bash command execution with configurable permission modes",
    "MCP (Model Context Protocol) server integration for extensibility",
    "Multi-agent swarm support for parallelizing complex tasks",
    "Hook system for running shell commands on tool events",
    "Skills system for on-demand repeatable workflows",
    "Memory system via CLAUDE.md files at global and project levels",
    "IDE integration (VS Code, JetBrains, etc.)",
    "Git-aware context and built-in commit/review workflows"
  ],
  "publicApiSurface": [
    "claude (CLI entrypoint)",
    "--print / -p (non-interactive output mode)",
    "--output-format (json|text|stream-json)",
    "--permission-mode (default|acceptEdits|bypassPermissions|plan)",
    "--model (model selection)",
    "--add-dir (additional context directories)",
    "--mcp-config (MCP server configuration)",
    "/init (generate CLAUDE.md for a project)",
    "/memory (edit memory files)",
    "/hooks (configure tool event hooks)",
    "/mcp (manage MCP servers)",
    "/permissions (manage tool permissions)",
    "/plan (enter plan mode)",
    "/model (switch models)",
    "/commit (AI-assisted git commit)",
    "/review (AI-powered code review)",
    "/skills (list available skills)",
    "/compact (summarize conversation context)",
    "BashTool",
    "FileReadTool (Read)",
    "FileEditTool",
    "FileWriteTool",
    "GlobTool",
    "GrepTool",
    "WebFetchTool",
    "WebSearchTool",
    "AgentTool (Task)",
    "TodoWriteTool",
